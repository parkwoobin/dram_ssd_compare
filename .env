# DRAM/SSD Compare - Environment Variables

# Database (default: local SQLite)
DATABASE_URL=sqlite+aiosqlite:///./data/prices.db

# Crawl window in KST [start, end)
# Example: 9~18 means 09:00 <= now < 18:00
CRAWL_START_HOUR=9
CRAWL_END_HOUR=18

# Runtime toggles
# If running multiple app replicas, enable scheduler only on one instance.
ENABLE_SCHEDULER=true
ENABLE_INITIAL_CRAWL=true
PRODUCT_RETENTION_DAYS=7
DOMAIN=dnw-smt-compare.duckdns.org
